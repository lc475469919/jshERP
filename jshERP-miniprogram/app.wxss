page {
  background: #f5f7f8;
  color: #1f2a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  padding: 24rpx;
}

.muted {
  color: #6b7a80;
}

.primary-button {
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
}

.secondary-button {
  background: #eef4f4;
  border-radius: 8rpx;
  color: #0f4f4a;
}
