<view class="page">
  <view class="form-section">
    <view class="field">
      <view class="field-label">账户名称</view>
      <input class="text-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">账号</view>
      <input class="text-input" value="{{serialNo}}" data-field="serialNo" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">期初金额</view>
      <input class="text-input" type="digit" value="{{initialAmount}}" data-field="initialAmount" bindinput="onInput" placeholder="默认0" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="saveAccount">{{isEdit ? '保存修改' : '保存账户'}}</button>
</view>
