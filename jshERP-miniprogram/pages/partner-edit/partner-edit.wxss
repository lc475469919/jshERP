.type-tabs {
  background: #e7eeee;
  border-radius: 8rpx;
  display: flex;
  margin-bottom: 24rpx;
  padding: 6rpx;
}

.type-tab {
  border-radius: 8rpx;
  color: #405057;
  flex: 1;
  font-size: 28rpx;
  line-height: 68rpx;
  text-align: center;
}

.type-tab.active {
  background: #ffffff;
  color: #0f766e;
  font-weight: 700;
}

.form-section {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.field {
  border-bottom: 1rpx solid #edf1f2;
  padding: 18rpx 0;
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  color: #6b7a80;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.text-input,
.textarea-input {
  color: #1f2a2e;
  font-size: 28rpx;
  width: 100%;
}

.text-input {
  height: 60rpx;
}

.textarea-input {
  background: #f5f7f8;
  border-radius: 8rpx;
  box-sizing: border-box;
  min-height: 150rpx;
  padding: 16rpx;
}

.save-button {
  font-size: 28rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  width: 100%;
}
