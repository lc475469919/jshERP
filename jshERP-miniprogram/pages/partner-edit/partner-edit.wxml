<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{type === '客户' ? 'active' : ''}}" data-type="客户" bindtap="switchType">客户</view>
    <view class="type-tab {{type === '供应商' ? 'active' : ''}}" data-type="供应商" bindtap="switchType">供应商</view>
  </view>

  <view class="form-section">
    <view class="field">
      <view class="field-label">单位名称</view>
      <input class="text-input" value="{{supplier}}" data-field="supplier" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">联系人</view>
      <input class="text-input" value="{{contacts}}" data-field="contacts" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">手机</view>
      <input class="text-input" value="{{telephone}}" data-field="telephone" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">电话</view>
      <input class="text-input" value="{{phoneNum}}" data-field="phoneNum" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">邮箱</view>
      <input class="text-input" value="{{email}}" data-field="email" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">税率</view>
      <input class="text-input" type="digit" value="{{taxRate}}" data-field="taxRate" bindinput="onInput" placeholder="默认0" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{description}}" data-field="description" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="savePartner">{{isEdit ? '保存修改' : '保存' + type}}</button>
</view>
