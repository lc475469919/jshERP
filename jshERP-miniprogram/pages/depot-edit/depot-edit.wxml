<view class="page">
  <view class="form-section">
    <view class="field">
      <view class="field-label">仓库名称</view>
      <input class="text-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">负责人</view>
      <input class="text-input" value="{{principal}}" data-field="principal" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">地址</view>
      <input class="text-input" value="{{address}}" data-field="address" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">排序</view>
      <input class="text-input" type="number" value="{{sort}}" data-field="sort" bindinput="onInput" placeholder="默认0" />
    </view>
    <view class="field-row">
      <view class="field half">
        <view class="field-label">仓储费</view>
        <input class="text-input" type="digit" value="{{warehousing}}" data-field="warehousing" bindinput="onInput" placeholder="默认0" />
      </view>
      <view class="field half">
        <view class="field-label">搬运费</view>
        <input class="text-input" type="digit" value="{{truckage}}" data-field="truckage" bindinput="onInput" placeholder="默认0" />
      </view>
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="saveDepot">{{isEdit ? '保存修改' : '保存仓库'}}</button>
</view>
