<view class="page">
  <view class="form-section">
    <view class="field">
      <view class="field-label">上级分类</view>
      <picker mode="selector" range="{{parents}}" range-key="title" value="{{parentIndex}}" bindchange="onParentChange">
        <view class="picker-value">{{parents[parentIndex].title}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">分类名称</view>
      <input class="text-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">分类编号</view>
      <input class="text-input" value="{{serialNo}}" data-field="serialNo" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">排序</view>
      <input class="text-input" value="{{sort}}" data-field="sort" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving || loading}}" bindtap="saveCategory">{{isEdit ? '保存修改' : '保存商品分类'}}</button>
</view>
