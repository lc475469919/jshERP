<view class="page">
  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="输入商品名称、条码或助记码" />
    <button class="secondary-button search-button" bindtap="search">查询</button>
  </view>

  <button class="primary-button add-button" bindtap="createMaterial">新增商品</button>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无商品</view>

  <view wx:for="{{list}}" wx:key="id" class="material-card" data-id="{{item.id}}" bindtap="openDetail">
    <view class="material-main">
      <view class="material-name">{{item.name || '未命名商品'}}</view>
      <view class="material-stock">库存 {{item.stock || 0}}</view>
    </view>
    <view class="material-meta">
      <text wx:if="{{item.mBarCode}}">条码：{{item.mBarCode}}</text>
      <text wx:if="{{item.standard}}">规格：{{item.standard}}</text>
      <text wx:if="{{item.model}}">型号：{{item.model}}</text>
      <text wx:if="{{item.unit || item.unitName}}">单位：{{item.unit || item.unitName}}</text>
    </view>
    <view class="price-row">
      <view>采购价：{{item.purchaseDecimal || '-'}}</view>
      <view>销售价：{{item.wholesaleDecimal || '-'}}</view>
    </view>
    <view class="card-actions">
      <view class="detail-hint">查看详情</view>
      <button class="secondary-button card-button" data-id="{{item.id}}" catchtap="editMaterial">编辑</button>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
