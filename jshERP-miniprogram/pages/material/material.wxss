.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.add-button {
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 24rpx;
  width: 100%;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.material-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.material-main {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.material-name {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

.material-stock {
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.material-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.price-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.card-actions {
  align-items: center;
  border-top: 1rpx solid #edf1f2;
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.detail-hint {
  color: #0f766e;
  font-size: 24rpx;
  text-align: right;
}

.card-button {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  width: 140rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
