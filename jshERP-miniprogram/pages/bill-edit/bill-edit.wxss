.kind-tabs {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.kind-tab {
  background: #e7eeee;
  border-radius: 8rpx;
  color: #405057;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
}

.kind-tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.form-section,
.items-section {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.field {
  border-bottom: 1rpx solid #edf1f2;
  padding: 18rpx 0;
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  color: #6b7a80;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.field-action {
  color: #0f766e;
  font-size: 24rpx;
  margin-top: 10rpx;
  text-align: right;
}

.readonly-value,
.picker-value,
.text-input {
  color: #1f2a2e;
  font-size: 28rpx;
  min-height: 48rpx;
}

.text-input {
  height: 56rpx;
}

.material-search {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 150rpx 170rpx;
  margin-bottom: 20rpx;
}

.search-input {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}

.add-material-button {
  font-size: 26rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0 0 20rpx;
  width: 100%;
}

.result-list {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.result-item {
  border-bottom: 1rpx solid #edf1f2;
  padding: 22rpx 24rpx;
}

.result-item:last-child {
  border-bottom: 0;
}

.result-name,
.item-name {
  color: #1f2a2e;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
}

.result-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 23rpx;
  gap: 6rpx;
  margin-top: 8rpx;
}

.section-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.state-text {
  color: #6b7a80;
  padding: 40rpx 0;
  text-align: center;
}

.item-card {
  border: 1rpx solid #edf1f2;
  border-radius: 8rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
}

.item-head {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
}

.item-code {
  color: #6b7a80;
  font-size: 22rpx;
  margin-top: 4rpx;
  word-break: break-all;
}

.remove {
  color: #b42318;
  font-size: 24rpx;
  line-height: 48rpx;
  white-space: nowrap;
}

.item-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr 1fr;
  margin-top: 18rpx;
}

.mini-label {
  color: #6b7a80;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.mini-input,
.amount-value {
  background: #f5f7f8;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #1f2a2e;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 14rpx;
}

.summary-bar {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.summary-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr;
  width: 260rpx;
}

.summary-label {
  color: #6b7a80;
  font-size: 22rpx;
}

.summary-amount {
  color: #0f766e;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.save-button {
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}
