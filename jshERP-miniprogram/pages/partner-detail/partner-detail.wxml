<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>

  <view class="partner-head">
    <view>
      <view class="partner-name">{{partner.displayName || '往来详情'}}</view>
      <view class="partner-type">{{partner.type || '-'}}</view>
    </view>
    <view class="partner-status">{{partner.statusText || '启用'}}</view>
  </view>
  <button class="primary-button edit-button" bindtap="editPartner">编辑往来单位</button>

  <view class="amount-panel">
    <view>
      <view class="amount-label">应收</view>
      <view class="amount-value">{{partner.needGetText || 0}}</view>
    </view>
    <view>
      <view class="amount-label">应付</view>
      <view class="amount-value">{{partner.needPayText || 0}}</view>
    </view>
    <view>
      <view class="amount-label">预收</view>
      <view class="amount-value">{{partner.advanceInText || 0}}</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">联系方式</view>
    <view class="info-list">
      <view class="info-row">
        <text>联系人</text>
        <text>{{partner.contacts || '-'}}</text>
      </view>
      <view class="info-row action" bindtap="callPhone">
        <text>电话</text>
        <text>{{partner.phoneText || '-'}}</text>
      </view>
      <view class="info-row">
        <text>邮箱</text>
        <text>{{partner.email || '-'}}</text>
      </view>
      <view class="info-row action" bindtap="copyAddress">
        <text>地址</text>
        <text>{{partner.address || '-'}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">开票信息</view>
    <view class="info-list">
      <view class="info-row">
        <text>税率</text>
        <text>{{partner.taxRateText || 0}}%</text>
      </view>
      <view class="info-row">
        <text>税号</text>
        <text>{{partner.taxNum || '-'}}</text>
      </view>
      <view class="info-row">
        <text>开户行</text>
        <text>{{partner.bankName || '-'}}</text>
      </view>
      <view class="info-row">
        <text>账号</text>
        <text>{{partner.accountNumber || '-'}}</text>
      </view>
      <view class="info-row">
        <text>备注</text>
        <text>{{partner.description || partner.remark || '-'}}</text>
      </view>
    </view>
  </view>
</view>
