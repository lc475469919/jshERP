.type-scroll {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.status-scroll {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.type-row,
.status-row {
  display: flex;
  gap: 16rpx;
}

.type-chip,
.status-chip {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  color: #405057;
  flex: 0 0 auto;
  font-size: 26rpx;
  line-height: 68rpx;
  padding: 0 28rpx;
}

.type-chip.active {
  background: #0f766e;
  border-color: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.status-chip {
  background: #eef4f4;
  font-size: 24rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
}

.status-chip.active {
  background: #0f766e;
  border-color: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.filter-card,
.bill-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.date-row {
  align-items: center;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.date-picker {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  line-height: 64rpx;
  min-width: 260rpx;
  padding: 0 18rpx;
  text-align: center;
}

.date-separator {
  color: #6b7a80;
}

.quick-row {
  color: #0f766e;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  justify-content: flex-end;
  margin-bottom: 18rpx;
}

.search-input {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.create-panel {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.create-action {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}

.create-action:first-child {
  grid-column: 1 / 3;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.bill-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.bill-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.bill-time {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.bill-amount {
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 700;
  max-width: 240rpx;
  text-align: right;
  word-break: break-all;
}

.status-pill {
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  margin-top: 10rpx;
  padding: 0 16rpx;
  text-align: center;
  white-space: nowrap;
}

.status-0 {
  background: #fff1f1;
  color: #b42318;
}

.status-1,
.status-2 {
  background: #e7f6ef;
  color: #0f766e;
}

.status-3,
.status-9 {
  background: #fff7df;
  color: #8a5a00;
}

.bill-meta {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
