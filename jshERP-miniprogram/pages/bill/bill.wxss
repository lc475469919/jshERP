.bill-tabs {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.bill-tab-row {
  display: flex;
  gap: 12rpx;
}

.bill-tab {
  background: #e7eeee;
  border-radius: 8rpx;
  color: #405057;
  flex: 0 0 auto;
  font-size: 26rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
}

.bill-tab.active {
  background: #ffffff;
  color: #0f766e;
  font-weight: 700;
}

.search-panel {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
  margin-bottom: 24rpx;
}

.date-row {
  align-items: center;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
}

.date-picker {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  line-height: 64rpx;
  min-width: 260rpx;
  padding: 0 18rpx;
  text-align: center;
}

.date-separator {
  color: #6b7a80;
}

.quick-row {
  color: #0f766e;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  justify-content: flex-end;
}

.search-input {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.search-action {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}

.create-panel {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.create-action {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}

.create-action:first-child {
  grid-column: 1 / 3;
}

.status-tabs {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.status-row {
  display: flex;
  gap: 12rpx;
}

.status-tab {
  background: #eef4f4;
  border-radius: 8rpx;
  color: #405057;
  flex: 0 0 auto;
  font-size: 24rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
}

.status-tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.bill-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.bill-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.bill-number {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.bill-status {
  border-radius: 8rpx;
  color: #405057;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.status-0 {
  background: #fff1f1;
  color: #b42318;
}

.status-1,
.status-2 {
  background: #e7f6ef;
  color: #0f766e;
}

.status-3,
.status-9 {
  background: #fff7df;
  color: #8a5a00;
}

.bill-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.amount-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.detail-hint {
  color: #0f766e;
  font-size: 24rpx;
  margin-top: 18rpx;
  text-align: right;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
