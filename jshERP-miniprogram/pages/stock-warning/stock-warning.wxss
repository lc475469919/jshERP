.filter-card,
.summary-card,
.warning-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.depot-picker {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #405057;
  font-size: 26rpx;
  line-height: 72rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.search-input {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.summary-label {
  color: #6b7a80;
  font-size: 24rpx;
}

.summary-value {
  color: #0f3f3c;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-top: 8rpx;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.warning-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.warning-name {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.warning-code {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.warning-badge {
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.warning-badge.low {
  background: #fff7df;
  color: #8a5a00;
}

.warning-badge.high {
  background: #fff1f1;
  color: #b42318;
}

.warning-badge.normal {
  background: #e7f6ef;
  color: #0f766e;
}

.warning-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.amount-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: grid;
  font-size: 24rpx;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.card-actions {
  align-items: center;
  border-top: 1rpx solid #edf1f2;
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.detail-hint {
  color: #0f766e;
  font-size: 24rpx;
}

.card-button {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  width: 160rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
