<view class="page">
  <view class="summary-card">
    <view class="summary-title">{{account.name || '账户流水'}}</view>
    <view class="summary-sub">余额：{{account.currentAmount || 0}}</view>
  </view>

  <view class="filter-card">
    <view class="date-row">
      <picker mode="date" value="{{beginTime}}" bindchange="onBeginDateChange">
        <view class="date-picker">{{beginTime}}</view>
      </picker>
      <view class="date-separator">至</view>
      <picker mode="date" value="{{endTime}}" bindchange="onEndDateChange">
        <view class="date-picker">{{endTime}}</view>
      </picker>
    </view>
    <view class="quick-row">
      <view data-range="month" bindtap="setQuickRange">本月</view>
      <view data-range="quarter" bindtap="setQuickRange">近三月</view>
      <view data-range="year" bindtap="setQuickRange">本年</view>
    </view>
    <view class="search-bar">
      <input class="search-input" value="{{number}}" bindinput="onNumberInput" confirm-type="search" bindconfirm="search" placeholder="单据编号" />
      <button class="secondary-button search-button" bindtap="search">查询</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无流水</view>

  <view wx:for="{{list}}" wx:key="number" class="flow-card">
    <view class="flow-main">
      <view>
        <view class="flow-number">{{item.number || '未编号流水'}}</view>
        <view class="flow-type">{{item.displayType}} · {{item.timeText}}</view>
      </view>
      <view class="flow-amount">{{item.amountText}}</view>
    </view>
    <view class="flow-meta">
      <text>往来单位：{{item.partnerText}}</text>
      <text>余额：{{item.balanceText}}</text>
      <text wx:if="{{item.remark}}">备注：{{item.remark}}</text>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
