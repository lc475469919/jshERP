.tabs {
  background: #ffffff;
  border: 1rpx solid #dce5e7;
  border-radius: 8rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
  padding: 6rpx;
}

.tab {
  border-radius: 8rpx;
  color: #405057;
  font-size: 28rpx;
  line-height: 72rpx;
  text-align: center;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.task-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.task-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.task-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.task-meta {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.task-amount {
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 700;
  max-width: 220rpx;
  text-align: right;
  word-break: break-all;
}

.task-grid {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: grid;
  font-size: 24rpx;
  gap: 12rpx;
  grid-template-columns: 1fr;
  margin-top: 20rpx;
  padding-top: 20rpx;
  word-break: break-all;
}

.task-actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 24rpx;
}

.approve-button,
.reject-button {
  border-radius: 8rpx;
  font-size: 28rpx;
}

.approve-button {
  background: #0f766e;
  color: #ffffff;
}

.reject-button {
  background: #fff1f0;
  color: #b42318;
}

.status-pill {
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.status-pending {
  background: #fff7df;
  color: #8a5a00;
}

.status-approved {
  background: #e7f6ef;
  color: #0f766e;
}

.status-rejected {
  background: #fff1f0;
  color: #b42318;
}

.status-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.status-tab {
  background: #ffffff;
  border: 1rpx solid #dce5e7;
  border-radius: 8rpx;
  color: #405057;
  font-size: 24rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
}

.status-tab.selected {
  background: #0f766e;
  border-color: #0f766e;
  color: #ffffff;
}
