<view class="page">
  <view class="tabs">
    <view class="tab {{activeTab === 'my' ? 'active' : ''}}" data-tab="my" bindtap="switchTab">待我审批</view>
    <view class="tab {{activeTab === 'submitted' ? 'active' : ''}}" data-tab="submitted" bindtap="switchTab">我提交的</view>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>

  <block wx:if="{{activeTab === 'my'}}">
    <view wx:if="{{!myTasks.length && !loading}}" class="state-text">暂无待审批单据</view>
    <view wx:for="{{myTasks}}" wx:key="id" class="task-card">
      <view class="task-main" data-task="{{item}}" bindtap="openBill">
        <view>
          <view class="task-title">{{item.moduleName || '审批单据'}} · {{item.billNo || '-'}}</view>
          <view class="task-meta">提交人：{{item.submitterText}}</view>
        </view>
        <view class="task-amount">{{item.amountText}}</view>
      </view>
      <view class="task-grid" data-task="{{item}}" bindtap="openBill">
        <view>单据类型：{{item.billSubType || item.billType || '-'}}</view>
        <view>审批岗位：{{item.roleText}}</view>
        <view>提交时间：{{item.timeText || '-'}}</view>
        <view>状态：{{item.statusText}}</view>
      </view>
      <view class="task-actions">
        <button class="reject-button" data-id="{{item.id}}" loading="{{processingId === item.id}}" bindtap="rejectTask">驳回</button>
        <button class="approve-button" data-id="{{item.id}}" loading="{{processingId === item.id}}" bindtap="approveTask">通过</button>
      </view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'submitted'}}">
    <view class="status-tabs">
      <view wx:for="{{statusOptions}}" wx:key="value" class="status-tab {{submittedStatus === item.value ? 'selected' : ''}}" data-status="{{item.value}}" bindtap="switchSubmittedStatus">
        {{item.label}}
      </view>
    </view>
    <view wx:if="{{!submittedTasks.length && !loading}}" class="state-text">暂无提交记录</view>
    <view wx:for="{{submittedTasks}}" wx:key="id" class="task-card" data-task="{{item}}" bindtap="openBill">
      <view class="task-main">
        <view>
          <view class="task-title">{{item.moduleName || '审批单据'}} · {{item.billNo || '-'}}</view>
          <view class="task-meta">审批岗位：{{item.roleText}}</view>
        </view>
        <view class="status-pill status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="task-grid">
        <view>单据类型：{{item.billSubType || item.billType || '-'}}</view>
        <view>金额：{{item.amountText}}</view>
        <view>提交时间：{{item.timeText || '-'}}</view>
        <view>审批人：{{item.approverName || '-'}}</view>
        <view wx:if="{{item.approveRemark}}">审批意见：{{item.approveRemark}}</view>
      </view>
    </view>
  </block>
</view>
