.summary-card,
.search-panel,
.bill-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.summary-title {
  color: #1f2a2e;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.summary-sub {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.search-panel {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
}

.search-input {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 100%;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.bill-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.bill-number {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.bill-status {
  border-radius: 8rpx;
  color: #405057;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.status-0 {
  background: #fff1f1;
  color: #b42318;
}

.status-1,
.status-2 {
  background: #e7f6ef;
  color: #0f766e;
}

.status-3,
.status-9 {
  background: #fff7df;
  color: #8a5a00;
}

.bill-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.amount-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.detail-hint {
  color: #0f766e;
  font-size: 24rpx;
  margin-top: 18rpx;
  text-align: right;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
