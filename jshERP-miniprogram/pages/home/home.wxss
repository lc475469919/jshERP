.hero {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  display: flex;
  justify-content: space-between;
  padding: 32rpx;
}

.welcome {
  color: #0f3f3c;
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.scan-button {
  font-size: 26rpx;
  margin: 0;
  width: 144rpx;
}

.grid {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1fr 1fr;
}

.overview {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  padding: 24rpx;
}

.section-title-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
}

.refresh-link {
  color: #0f766e;
  font-size: 24rpx;
}

.stat-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.stat-card {
  background: #f5f7f8;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  box-sizing: border-box;
  min-height: 128rpx;
  padding: 20rpx;
}

.stat-label {
  color: #6b7a80;
  font-size: 24rpx;
}

.stat-value {
  color: #0f3f3c;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-top: 8rpx;
  word-break: break-all;
}

.retail-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.quick-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  box-sizing: border-box;
  min-height: 180rpx;
  padding: 24rpx;
}

.quick-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 600;
}

.quick-text {
  color: #6b7a80;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 16rpx;
}

.approval-card {
  border-color: #9fd5ce;
}
