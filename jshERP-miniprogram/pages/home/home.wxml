<view class="page">
  <view class="section hero">
    <view>
      <view class="welcome">{{platformName}}</view>
      <view class="muted">你好，{{user.username || user.loginName || '用户'}}</view>
    </view>
    <button class="secondary-button scan-button" bindtap="scanCode">扫码</button>
  </view>

  <view class="section overview">
    <view class="section-title-row">
      <view class="section-title">经营概览</view>
      <view class="refresh-link" bindtap="refreshStatistics">{{statLoading ? '刷新中' : '刷新'}}</view>
    </view>
    <view class="stat-grid">
      <view class="stat-card">
        <view class="stat-label">今日销售</view>
        <view class="stat-value">{{statistics.todaySale || 0}}</view>
      </view>
      <view class="stat-card">
        <view class="stat-label">今日采购</view>
        <view class="stat-value">{{statistics.todayBuy || 0}}</view>
      </view>
      <view class="stat-card">
        <view class="stat-label">本月销售</view>
        <view class="stat-value">{{statistics.monthSale || 0}}</view>
      </view>
      <view class="stat-card">
        <view class="stat-label">本月采购</view>
        <view class="stat-value">{{statistics.monthBuy || 0}}</view>
      </view>
    </view>
    <view class="retail-row">
      <view>今日零售：{{statistics.todayRetailSale || 0}}</view>
      <view>本月零售：{{statistics.monthRetailSale || 0}}</view>
    </view>
  </view>

  <view class="section grid">
    <view class="quick-card approval-card" bindtap="goApproval">
      <view class="quick-title">审批中心</view>
      <view class="quick-text">{{approvalCount}} 条待我审批</view>
    </view>
    <view class="quick-card" bindtap="goAccountReport">
      <view class="quick-title">往来账款</view>
      <view class="quick-text">查应收应付</view>
    </view>
    <view class="quick-card" bindtap="goMaterial">
      <view class="quick-title">商品库存</view>
      <view class="quick-text">查条码、名称和库存</view>
    </view>
    <view class="quick-card" data-type="销售出库" bindtap="goBill">
      <view class="quick-title">销售出库</view>
      <view class="quick-text">查销售出库单</view>
    </view>
    <view class="quick-card" data-type="采购入库" bindtap="goBill">
      <view class="quick-title">采购入库</view>
      <view class="quick-text">查采购入库单</view>
    </view>
    <view class="quick-card" bindtap="goStockReport">
      <view class="quick-title">经营报表</view>
      <view class="quick-text">查库存报表</view>
    </view>
    <view class="quick-card" bindtap="goBuySaleReport">
      <view class="quick-title">购销统计</view>
      <view class="quick-text">查采购、销售、零售</view>
    </view>
    <view class="quick-card" bindtap="goAccountList">
      <view class="quick-title">资金账户</view>
      <view class="quick-text">查余额流水</view>
    </view>
    <view class="quick-card" bindtap="goFinanceBill">
      <view class="quick-title">财务单据</view>
      <view class="quick-text">查收付款单</view>
    </view>
    <view class="quick-card" bindtap="goProduction">
      <view class="quick-title">生产管理</view>
      <view class="quick-text">查BOM和生产单</view>
    </view>
    <view class="quick-card" bindtap="goDepot">
      <view class="quick-title">仓库资料</view>
      <view class="quick-text">查仓库信息</view>
    </view>
    <view class="quick-card" bindtap="goStockWarning">
      <view class="quick-title">库存预警</view>
      <view class="quick-text">查安全库存</view>
    </view>
  </view>
</view>
