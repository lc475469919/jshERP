<view class="page">
  <view class="form-section">
    <view class="field">
      <view class="field-label">基础单位</view>
      <input class="text-input" value="{{basicUnit}}" data-field="basicUnit" bindinput="onInput" placeholder="例如：个" />
    </view>
    <view class="field">
      <view class="field-label">换算单位</view>
      <input class="text-input" value="{{otherUnit}}" data-field="otherUnit" bindinput="onInput" placeholder="例如：箱" />
    </view>
    <view class="field">
      <view class="field-label">换算比例</view>
      <input class="text-input" type="digit" value="{{ratio}}" data-field="ratio" bindinput="onInput" placeholder="例如：12，表示1箱=12个" />
    </view>
    <view class="field">
      <view class="field-label">第二换算单位</view>
      <input class="text-input" value="{{otherUnitTwo}}" data-field="otherUnitTwo" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">第二换算比例</view>
      <input class="text-input" type="digit" value="{{ratioTwo}}" data-field="ratioTwo" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">第三换算单位</view>
      <input class="text-input" value="{{otherUnitThree}}" data-field="otherUnitThree" bindinput="onInput" placeholder="可不填" />
    </view>
    <view class="field">
      <view class="field-label">第三换算比例</view>
      <input class="text-input" type="digit" value="{{ratioThree}}" data-field="ratioThree" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="saveUnit">{{isEdit ? '保存修改' : '保存计量单位'}}</button>
</view>
