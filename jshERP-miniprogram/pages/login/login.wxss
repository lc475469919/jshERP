.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 96rpx 32rpx 32rpx;
  background: #f5f7f8;
}

.brand {
  margin-bottom: 56rpx;
}

.brand-title {
  color: #0f3f3c;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}

.brand-subtitle {
  color: #6b7a80;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.login-panel {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  color: #405057;
  display: block;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.input {
  background: #f8fafb;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 24rpx;
  width: 100%;
}

.login-button {
  margin-top: 36rpx;
}

.captcha-field {
  align-items: flex-end;
  display: flex;
  gap: 16rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-image {
  background: #f8fafb;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  height: 88rpx;
  width: 220rpx;
}

.tip {
  color: #6b7a80;
  font-size: 24rpx;
  line-height: 1.7;
  margin-top: 28rpx;
}
