<view class="page">
  <view class="tabs">
    <view class="tab {{type === 'buy' ? 'active' : ''}}" data-type="buy" bindtap="changeType">采购</view>
    <view class="tab {{type === 'sale' ? 'active' : ''}}" data-type="sale" bindtap="changeType">销售</view>
    <view class="tab {{type === 'retail' ? 'active' : ''}}" data-type="retail" bindtap="changeType">零售</view>
  </view>

  <view class="filter-card">
    <picker mode="selector" range="{{depotList}}" range-key="depotName" value="{{depotIndex}}" bindchange="onDepotChange">
      <view class="depot-picker">{{currentDepotName}}</view>
    </picker>
    <view class="date-row">
      <picker mode="date" value="{{beginTime}}" bindchange="onBeginDateChange">
        <view class="date-picker">{{beginTime}}</view>
      </picker>
      <view class="date-separator">至</view>
      <picker mode="date" value="{{endTime}}" bindchange="onEndDateChange">
        <view class="date-picker">{{endTime}}</view>
      </picker>
    </view>
    <view class="search-bar">
      <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="商品名称、条码、规格" />
      <button class="secondary-button search-button" bindtap="search">查询</button>
    </view>
    <view class="quick-row">
      <view data-range="month" bindtap="setQuickRange">本月</view>
      <view data-range="quarter" bindtap="setQuickRange">近三月</view>
      <view data-range="year" bindtap="setQuickRange">本年</view>
    </view>
  </view>

  <view class="summary-card">
    <view>
      <view class="summary-label">{{reportTitle}}金额</view>
      <view class="summary-value">{{totalAmount || 0}}</view>
    </view>
    <view class="summary-count">商品 {{total || 0}} 项</view>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无{{reportTitle}}数据</view>

  <view wx:for="{{list}}" wx:key="barCode" class="report-card" data-barcode="{{item.barCode}}" bindtap="openMaterial">
    <view class="report-main">
      <view>
        <view class="report-name">{{item.displayName}}</view>
        <view class="report-code" wx:if="{{item.barCode}}">条码：{{item.barCode}}</view>
      </view>
      <view class="report-amount">{{item.amountText}}</view>
    </view>
    <view class="report-meta">
      <text wx:if="{{item.specText}}">规格：{{item.specText}}</text>
      <text>单位：{{item.unitText}}</text>
    </view>
    <view class="amount-row">
      <view>{{inLabel}}：{{item.inText}}</view>
      <view>{{outLabel}}：{{item.outText}}</view>
      <view>{{inLabel}}额：{{item.inPriceText}}</view>
      <view>{{outLabel}}额：{{item.outPriceText}}</view>
    </view>
    <view class="detail-hint">查看商品</view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
