<view class="page">
  <view class="card user-card">
    <view class="avatar">{{avatarText}}</view>
    <view>
      <view class="user-name">{{user.username || user.loginName || '未登录'}}</view>
      <view class="muted">{{user.position || '移动端用户'}}</view>
    </view>
  </view>

  <view class="card info-card">
    <view class="row">
      <text>登录账号</text>
      <text>{{user.loginName || '-'}}</text>
    </view>
    <view class="row">
      <text>服务地址</text>
      <text class="url" bindtap="copyBaseUrl">{{baseUrl}}</text>
    </view>
    <view class="row">
      <text>连接状态</text>
      <text>{{serverStatus}}</text>
    </view>
    <view class="row action-row" bindtap="goMessage">
      <text>消息中心</text>
      <text>{{unreadCount}} 条未读</text>
    </view>
    <view class="row action-row" bindtap="goApproval">
      <text>审批中心</text>
      <text>{{approvalCount}} 条待审</text>
    </view>
    <view class="row action-row" bindtap="goBasicData">
      <text>基础资料</text>
      <text>经手人、项目、单位、分类</text>
    </view>
  </view>

  <view class="card info-card">
    <view class="section-title">小程序配置</view>
    <view class="row">
      <text>AppID</text>
      <text class="url" data-value="{{miniConfig.miniprogram_appid}}" bindtap="copyConfigValue">{{miniConfig.miniprogram_appid || '-'}}</text>
    </view>
    <view class="row">
      <text>电脑端 API 地址</text>
      <text class="url" data-value="{{miniConfig.miniprogram_api_base_url}}" bindtap="copyConfigValue">{{miniConfig.miniprogram_api_base_url || '-'}}</text>
    </view>
    <view class="row">
      <text>request 域名</text>
      <text class="url" data-value="{{miniConfig.miniprogram_request_domain}}" bindtap="copyConfigValue">{{miniConfig.miniprogram_request_domain || '-'}}</text>
    </view>
    <view class="row" wx:if="{{miniConfig.miniprogram_remark}}">
      <text>备注</text>
      <text class="url" data-value="{{miniConfig.miniprogram_remark}}" bindtap="copyConfigValue">{{miniConfig.miniprogram_remark}}</text>
    </view>
  </view>

  <button class="secondary-button action" bindtap="checkServer">{{checking ? '检测中' : '检测服务连接'}}</button>
  <button class="secondary-button action" loading="{{configLoading}}" bindtap="loadMiniProgramConfig">读取电脑端小程序配置</button>
  <button class="secondary-button action" bindtap="applyDesktopApiUrl">应用电脑端 API 地址</button>
  <button class="secondary-button action" bindtap="refreshSession">刷新用户信息</button>
  <button class="logout-button action" bindtap="logout">退出登录</button>
</view>
