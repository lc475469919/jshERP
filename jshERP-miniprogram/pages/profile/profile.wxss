.user-card {
  align-items: center;
  display: flex;
  gap: 24rpx;
}

.avatar {
  align-items: center;
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
  display: flex;
  font-size: 36rpx;
  font-weight: 700;
  height: 96rpx;
  justify-content: center;
  width: 96rpx;
}

.user-name {
  color: #1f2a2e;
  font-size: 34rpx;
  font-weight: 700;
}

.info-card {
  margin-top: 24rpx;
}

.section-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  padding-bottom: 18rpx;
}

.row {
  align-items: flex-start;
  border-bottom: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 26rpx;
  justify-content: space-between;
  padding: 24rpx 0;
}

.row:first-child {
  padding-top: 0;
}

.row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.url {
  color: #0f766e;
  max-width: 420rpx;
  overflow-wrap: break-word;
  text-align: right;
}

.action-row text:last-child {
  color: #0f766e;
}

.action {
  margin-top: 24rpx;
}

.logout-button {
  background: #fff1f0;
  border-radius: 8rpx;
  color: #b42318;
}
