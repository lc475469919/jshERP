<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{type === '客户' ? 'active' : ''}}" data-type="客户" bindtap="changeType">客户</view>
    <view class="type-tab {{type === '供应商' ? 'active' : ''}}" data-type="供应商" bindtap="changeType">供应商</view>
  </view>

  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="输入名称、联系人或电话" />
    <button class="secondary-button search-button" bindtap="search">查询</button>
  </view>

  <button class="primary-button add-button" bindtap="createPartner">新增{{type}}</button>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无{{type}}</view>

  <view wx:for="{{list}}" wx:key="id" class="partner-card" data-id="{{item.id}}" bindtap="openDetail">
    <view class="partner-main">
      <view class="partner-name">{{item.supplier || '未命名'}}</view>
      <view class="partner-status">{{item.enabled ? '启用' : '停用'}}</view>
    </view>
    <view class="partner-meta">
      <text wx:if="{{item.contacts}}">联系人：{{item.contacts}}</text>
      <text wx:if="{{item.telephone}}">手机：{{item.telephone}}</text>
      <text wx:if="{{item.phoneNum}}">电话：{{item.phoneNum}}</text>
      <text wx:if="{{item.email}}">邮箱：{{item.email}}</text>
    </view>
    <view class="amount-row">
      <view wx:if="{{type === '客户'}}">应收：{{item.allNeedGet || 0}}</view>
      <view wx:if="{{type === '供应商'}}">应付：{{item.allNeedPay || 0}}</view>
      <view>税率：{{item.taxRate || 0}}%</view>
    </view>
    <view class="card-actions">
      <button class="secondary-button card-button" data-id="{{item.id}}" catchtap="editPartner">编辑</button>
      <button class="danger-button card-button" data-id="{{item.id}}" catchtap="deletePartner">删除</button>
    </view>
    <view class="detail-hint">点击卡片查看详情</view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
