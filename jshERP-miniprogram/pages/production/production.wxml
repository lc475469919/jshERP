<view class="page">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="value" class="tab {{activeTab === item.value ? 'active' : ''}}" data-type="{{item.value}}" bindtap="changeTab">{{item.label}}</view>
  </view>

  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="{{activeTab === 'bom' ? '输入BOM、成品名称' : '输入生产单号、成品名称'}}" />
    <button class="secondary-button search-button" bindtap="search">查询</button>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">{{activeTab === 'bom' ? '暂无BOM' : '暂无生产单'}}</view>

  <view wx:if="{{activeTab === 'bom'}}">
    <view wx:for="{{list}}" wx:key="id" class="production-card">
      <view class="card-main">
        <view class="card-title">{{item.name || '未命名BOM'}}</view>
        <view class="status-tag">{{item.enabled ? '启用' : '停用'}}</view>
      </view>
      <view class="card-meta">
        <view>编号：{{item.bomNo || '-'}}</view>
        <view>成品：{{item.materialName || '-'}}</view>
        <view>产出：{{item.outputQuantity || 1}}{{item.materialUnit || ''}}</view>
      </view>
      <view class="detail-hint">先在接口创建和维护BOM，页面编辑稍后接入</view>
    </view>
  </view>

  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="production-card">
      <view class="card-main">
        <view class="card-title">{{item.orderNo || '未命名生产单'}}</view>
        <view class="status-tag">{{item.status || '草稿'}}</view>
      </view>
      <view class="card-meta">
        <view>成品：{{item.materialName || '-'}}</view>
        <view>计划：{{item.planQuantity || 0}}{{item.materialUnit || ''}}</view>
        <view>完工：{{item.finishedQuantity || 0}}{{item.materialUnit || ''}}</view>
      </view>
      <view class="detail-hint">领料和入库动作稍后接入</view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
