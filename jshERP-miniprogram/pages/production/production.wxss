.tabs {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  display: flex;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab {
  color: #5f6b70;
  flex: 1;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 600;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  background: #ffffff;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.production-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.card-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.card-title {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

.status-tag {
  background: #e8f6f3;
  border-radius: 8rpx;
  color: #0f766e;
  font-size: 24rpx;
  padding: 8rpx 14rpx;
  white-space: nowrap;
}

.card-meta {
  color: #405057;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.detail-hint {
  border-top: 1rpx solid #edf1f2;
  color: #0f766e;
  font-size: 24rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  text-align: right;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
