.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.material-head,
.stock-panel,
.section-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.material-head {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.material-name {
  color: #1f2a2e;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.material-code {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 10rpx;
  word-break: break-all;
}

.material-status {
  background: #e7f6ef;
  border-radius: 8rpx;
  color: #0f766e;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.edit-button {
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 20rpx;
  width: 100%;
}

.stock-panel {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1fr 1fr;
}

.panel-label,
.info-label {
  color: #6b7a80;
  font-size: 22rpx;
}

.stock-value {
  color: #0f3f3c;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-top: 8rpx;
  word-break: break-all;
}

.panel-value,
.info-value {
  color: #1f2a2e;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  margin-top: 8rpx;
  word-break: break-all;
}

.section-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.info-grid {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1fr 1fr;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.empty-line {
  color: #6b7a80;
  font-size: 24rpx;
  padding: 12rpx 0;
}

.depot-stock-row {
  align-items: flex-start;
  border-top: 1rpx solid #edf1f2;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 18rpx 0;
}

.depot-stock-row:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.depot-name {
  color: #1f2a2e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.depot-safe {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.depot-stock-number {
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
  max-width: 240rpx;
  text-align: right;
  word-break: break-all;
}

.depot-stock-number text {
  color: #6b7a80;
  display: block;
  font-size: 22rpx;
  font-weight: 400;
  margin-top: 6rpx;
}

.info-row {
  align-items: flex-start;
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  gap: 20rpx;
  justify-content: space-between;
  line-height: 1.6;
  padding: 18rpx 0;
}

.info-row:first-child {
  border-top: 0;
  padding-top: 0;
}

.info-row text:first-child {
  color: #6b7a80;
  flex: 0 0 150rpx;
}

.info-row text:last-child {
  flex: 1;
  text-align: right;
  word-break: break-all;
}
