<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>

  <view class="material-head">
    <view>
      <view class="material-name">{{material.displayName || '商品详情'}}</view>
      <view class="material-code" bindtap="copyBarCode">条码：{{material.barCodeText || '-'}}</view>
    </view>
    <view class="material-status">{{material.statusText || '启用'}}</view>
  </view>
  <button class="primary-button edit-button" bindtap="editMaterial">编辑商品</button>

  <view class="stock-panel">
    <view>
      <view class="panel-label">当前库存</view>
      <view class="stock-value">{{material.stockText || 0}}</view>
    </view>
    <view>
      <view class="panel-label">单位</view>
      <view class="panel-value">{{material.unitText || '-'}}</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">价格</view>
    <view class="info-grid">
      <view>
        <view class="info-label">采购价</view>
        <view class="info-value">{{material.purchaseText || '-'}}</view>
      </view>
      <view>
        <view class="info-label">销售价</view>
        <view class="info-value">{{material.saleText || '-'}}</view>
      </view>
      <view>
        <view class="info-label">零售价</view>
        <view class="info-value">{{material.retailText || '-'}}</view>
      </view>
      <view>
        <view class="info-label">最低售价</view>
        <view class="info-value">{{material.lowText || '-'}}</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">分仓库存</view>
    <view wx:if="{{!depotStocks.length}}" class="empty-line">暂无分仓库存</view>
    <view wx:for="{{depotStocks}}" wx:key="id" class="depot-stock-row">
      <view>
        <view class="depot-name">{{item.displayName}}</view>
        <view class="depot-safe">安全库存：{{item.lowText}} - {{item.highText}}</view>
      </view>
      <view class="depot-stock-number">
        <view>{{item.currentText}}</view>
        <text>期初 {{item.initText}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">基础信息</view>
    <view class="info-list">
      <view class="info-row">
        <text>分类</text>
        <text>{{material.categoryText || '-'}}</text>
      </view>
      <view class="info-row">
        <text>规格型号</text>
        <text>{{material.specText || '-'}}</text>
      </view>
      <view class="info-row">
        <text>SKU</text>
        <text>{{material.skuText || '-'}}</text>
      </view>
      <view class="info-row">
        <text>品牌</text>
        <text>{{material.brand || '-'}}</text>
      </view>
      <view class="info-row">
        <text>制造商</text>
        <text>{{material.mfrs || '-'}}</text>
      </view>
      <view class="info-row">
        <text>货位</text>
        <text>{{material.position || '-'}}</text>
      </view>
      <view class="info-row">
        <text>备注</text>
        <text>{{material.remark || '-'}}</text>
      </view>
    </view>
  </view>
</view>
