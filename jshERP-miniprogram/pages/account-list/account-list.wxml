<view class="page">
  <view class="summary-card">
    <view class="summary-label">账户余额合计</view>
    <view class="summary-value">{{totalAmount}}</view>
  </view>

  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="账户名称" />
    <button class="secondary-button search-button" bindtap="search">查询</button>
  </view>

  <button class="primary-button add-button" bindtap="createAccount">新增资金账户</button>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无账户</view>

  <view wx:for="{{list}}" wx:key="id" class="account-card" data-id="{{item.id}}" bindtap="openFlow">
    <view class="account-main">
      <view>
        <view class="account-name">{{item.displayName}}</view>
        <view class="account-no" wx:if="{{item.serialNo}}">{{item.serialNo}}</view>
      </view>
      <view class="account-balance">{{item.currentText}}</view>
    </view>
    <view class="account-meta">
      <text>{{item.statusText}}{{item.isDefault ? ' · 默认账户' : ''}}</text>
      <text>期初：{{item.initialText}}</text>
      <text>本月发生：{{item.monthText}}</text>
      <text wx:if="{{item.remark}}">备注：{{item.remark}}</text>
    </view>
    <view class="card-actions">
      <view class="detail-hint">查看流水</view>
      <view class="button-row">
        <button wx:if="{{!item.isDefault}}" class="secondary-button card-button wide" data-id="{{item.id}}" catchtap="setDefaultAccount">设为默认</button>
        <button class="secondary-button card-button" data-id="{{item.id}}" catchtap="editAccount">编辑</button>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
