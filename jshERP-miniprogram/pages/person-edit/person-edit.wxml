<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{type === '销售员' ? 'active' : ''}}" data-type="销售员" bindtap="switchType">销售员</view>
    <view class="type-tab {{type === '仓管员' ? 'active' : ''}}" data-type="仓管员" bindtap="switchType">仓管员</view>
    <view class="type-tab {{type === '财务员' ? 'active' : ''}}" data-type="财务员" bindtap="switchType">财务员</view>
  </view>

  <view class="form-section">
    <view class="field">
      <view class="field-label">姓名</view>
      <input class="text-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">排序</view>
      <input class="text-input" type="number" value="{{sort}}" data-field="sort" bindinput="onInput" placeholder="默认0" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="savePerson">{{isEdit ? '保存修改' : '保存' + type}}</button>
</view>
