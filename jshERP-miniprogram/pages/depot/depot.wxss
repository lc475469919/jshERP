.search-bar,
.depot-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.search-input {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.add-button {
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 24rpx;
  width: 100%;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.depot-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.depot-name {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.depot-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.depot-tag,
.depot-type {
  background: #e7f6ef;
  border-radius: 8rpx;
  color: #0f766e;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
}

.depot-type {
  white-space: nowrap;
}

.depot-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.amount-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.card-actions {
  border-top: 1rpx solid #edf1f2;
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.card-button {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  width: 140rpx;
}

.card-button.wide {
  width: 180rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
