.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.detail-card,
.approval-card,
.amount-panel,
.item-card,
.finance-card,
.total-row {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
}

.detail-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.detail-head {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.detail-title {
  color: #1f2a2e;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.detail-number {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 8rpx;
  word-break: break-all;
}

.detail-status {
  border-radius: 8rpx;
  color: #405057;
  font-size: 22rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  white-space: nowrap;
}

.status-0 {
  background: #fff1f1;
  color: #b42318;
}

.status-1,
.status-2 {
  background: #e7f6ef;
  color: #0f766e;
}

.status-3,
.status-9 {
  background: #fff7df;
  color: #8a5a00;
}

.info-grid {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 28rpx;
}

.info-label,
.amount-label {
  color: #6b7a80;
  font-size: 22rpx;
}

.info-value {
  color: #1f2a2e;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 8rpx;
  word-break: break-all;
}

.contact-row,
.remark-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 20rpx;
  padding-top: 20rpx;
  word-break: break-all;
}

.amount-panel {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr 1fr;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.amount-value {
  color: #0f3f3c;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-top: 8rpx;
  word-break: break-all;
}

.section-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.item-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.item-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.item-name {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

.item-qty {
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.item-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.item-price,
.total-row {
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
}

.item-price {
  border-top: 1rpx solid #edf1f2;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.total-row {
  margin-bottom: 56rpx;
  padding: 24rpx;
}

.finance-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.finance-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.finance-title {
  color: #1f2a2e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.finance-account {
  color: #6b7a80;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.finance-amount {
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
  max-width: 240rpx;
  text-align: right;
  word-break: break-all;
}

.approval-button,
.danger-button {
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 28rpx;
  margin-top: 24rpx;
}

.danger-button {
  background: #b42318;
}

.approval-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.approval-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.approval-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
}

.approval-status {
  color: #0f766e;
  font-size: 24rpx;
}

.approval-grid {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: grid;
  font-size: 24rpx;
  gap: 12rpx;
  grid-template-columns: 1fr;
  margin-top: 18rpx;
  padding-top: 18rpx;
  word-break: break-all;
}

.status-border-pending {
  border-left: 8rpx solid #f59e0b;
}

.status-border-approved {
  border-left: 8rpx solid #0f766e;
}

.status-border-rejected {
  border-left: 8rpx solid #b42318;
}
