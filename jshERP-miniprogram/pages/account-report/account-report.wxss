.type-tabs,
.filter-card,
.summary-card,
.account-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.type-tabs {
  display: flex;
  padding: 6rpx;
}

.type-tab {
  border-radius: 8rpx;
  color: #405057;
  flex: 1;
  font-size: 28rpx;
  line-height: 68rpx;
  text-align: center;
}

.type-tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.filter-card {
  padding: 24rpx;
}

.date-row {
  align-items: center;
  color: #405057;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.date-picker {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  line-height: 64rpx;
  min-width: 260rpx;
  padding: 0 18rpx;
  text-align: center;
}

.date-separator {
  color: #6b7a80;
}

.debt-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.quick-row {
  color: #0f766e;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  justify-content: flex-end;
  margin-bottom: 18rpx;
}

.debt-tab {
  background: #eef4f4;
  border-radius: 8rpx;
  color: #405057;
  font-size: 26rpx;
  line-height: 68rpx;
  text-align: center;
}

.debt-tab.active {
  background: #e7f6ef;
  color: #0f766e;
  font-weight: 700;
}

.summary-card {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1fr 1fr;
  padding: 24rpx;
}

.summary-label {
  color: #6b7a80;
  font-size: 22rpx;
}

.summary-value {
  color: #0f3f3c;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-top: 8rpx;
  word-break: break-all;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.account-card {
  padding: 24rpx;
}

.account-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.account-name {
  color: #1f2a2e;
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.account-need {
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
  white-space: nowrap;
}

.account-meta {
  color: #6b7a80;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 16rpx;
}

.amount-row {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.card-actions {
  align-items: center;
  border-top: 1rpx solid #edf1f2;
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.detail-hint {
  color: #0f766e;
  font-size: 24rpx;
  text-align: right;
}

.card-button {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  width: 160rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
