<view class="page">
  <view class="tabs">
    <view wx:for="{{typeList}}" wx:key="value" class="tab {{type === item.value ? 'active' : ''}}" data-type="{{item.value}}" bindtap="changeType">{{item.label}}</view>
  </view>

  <view class="filter-card">
    <view class="search-bar">
      <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" placeholder="名称" />
      <button class="secondary-button search-button" bindtap="search">查询</button>
    </view>
  </view>

  <button wx:if="{{type === 'person'}}" class="primary-button add-button" bindtap="createCurrent">新增经手人</button>
  <button wx:if="{{type === 'inOutItem'}}" class="primary-button add-button" bindtap="createCurrent">新增收支项目</button>
  <button wx:if="{{type === 'unit'}}" class="primary-button add-button" bindtap="createCurrent">新增计量单位</button>
  <button wx:if="{{type === 'category'}}" class="primary-button add-button" bindtap="createCurrent">新增商品分类</button>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无基础资料</view>

  <view wx:for="{{list}}" wx:key="id" class="data-card">
    <view class="data-main">
      <view class="data-title">{{item.titleText}}</view>
      <view class="data-tag">{{item.tagText}}</view>
    </view>
    <view class="data-lines">
      <text>{{item.lineOne}}</text>
      <text>{{item.lineTwo}}</text>
      <text wx:if="{{item.lineThree}}">{{item.lineThree}}</text>
    </view>
    <view class="card-actions">
      <button class="secondary-button card-button" data-id="{{item.id}}" bindtap="editCurrent">编辑</button>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
