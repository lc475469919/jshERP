.tabs,
.filter-card,
.data-card {
  background: #ffffff;
  border: 1rpx solid #e1e7ea;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.tabs {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(4, 1fr);
}

.tab {
  background: #f5f7f8;
  border-radius: 8rpx;
  color: #405057;
  font-size: 26rpx;
  line-height: 68rpx;
  text-align: center;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.search-input {
  background: #f5f7f8;
  border: 1rpx solid #dbe4e7;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
}

.search-button {
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  width: 132rpx;
}

.add-button {
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 24rpx;
  width: 100%;
}

.state-text {
  color: #6b7a80;
  padding: 80rpx 0;
  text-align: center;
}

.data-main {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.data-title {
  color: #1f2a2e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.data-tag {
  background: #eef4f4;
  border-radius: 8rpx;
  color: #0f4f4a;
  flex: 0 0 auto;
  font-size: 24rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
}

.data-lines {
  border-top: 1rpx solid #edf1f2;
  color: #405057;
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  word-break: break-all;
}

.card-actions {
  border-top: 1rpx solid #edf1f2;
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.card-button {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  width: 140rpx;
}

.load-more {
  color: #0f766e;
  padding: 28rpx 0 56rpx;
  text-align: center;
}
