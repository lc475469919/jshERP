<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{type === '收入' ? 'active' : ''}}" data-type="收入" bindtap="switchType">收入</view>
    <view class="type-tab {{type === '支出' ? 'active' : ''}}" data-type="支出" bindtap="switchType">支出</view>
  </view>

  <view class="form-section">
    <view class="field">
      <view class="field-label">项目名称</view>
      <input class="text-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">排序</view>
      <input class="text-input" type="number" value="{{sort}}" data-field="sort" bindinput="onInput" placeholder="默认0" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="saveItem">{{isEdit ? '保存修改' : '保存' + type + '项目'}}</button>
</view>
