<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{type === '收款' ? 'active' : ''}}" data-type="收款" bindtap="switchType">收款</view>
    <view class="type-tab {{type === '付款' ? 'active' : ''}}" data-type="付款" bindtap="switchType">付款</view>
    <view class="type-tab {{type === '收入' ? 'active' : ''}}" data-type="收入" bindtap="switchType">收入</view>
    <view class="type-tab {{type === '支出' ? 'active' : ''}}" data-type="支出" bindtap="switchType">支出</view>
    <view class="type-tab {{type === '转账' ? 'active' : ''}}" data-type="转账" bindtap="switchType">转账</view>
  </view>

  <view class="form-section">
    <view class="field">
      <view class="field-label">财务单号</view>
      <view class="readonly-value">{{billNo || '生成中...'}}</view>
    </view>
    <view wx:if="{{config.usePartner}}" class="field">
      <view class="field-label">{{config.partnerType}}</view>
      <picker mode="selector" range="{{partners}}" range-key="supplier" value="{{partnerIndex}}" bindchange="onPartnerChange">
        <view class="picker-value">{{partnerIndex >= 0 ? partners[partnerIndex].supplier : '请选择'}}</view>
      </picker>
      <view class="field-action" bindtap="createPartner">新增{{config.partnerType}}</view>
    </view>
    <view class="field">
      <view class="field-label">{{config.useTransfer ? '付款账户' : '账户'}}</view>
      <picker mode="selector" range="{{accounts}}" range-key="name" value="{{accountIndex}}" bindchange="onAccountChange">
        <view class="picker-value">{{accountIndex >= 0 ? accounts[accountIndex].name : '请选择'}}</view>
      </picker>
      <view class="field-action" bindtap="createAccount">新增账户</view>
    </view>
    <view wx:if="{{config.useTransfer}}" class="field">
      <view class="field-label">收款账户</view>
      <picker mode="selector" range="{{accounts}}" range-key="name" value="{{targetAccountIndex}}" bindchange="onTargetAccountChange">
        <view class="picker-value">{{targetAccountIndex >= 0 ? accounts[targetAccountIndex].name : '请选择'}}</view>
      </picker>
      <view class="field-action" bindtap="createAccount">新增账户</view>
    </view>
    <view wx:if="{{config.useItem}}" class="field">
      <view class="field-label">收支项目</view>
      <picker mode="selector" range="{{inOutItems}}" range-key="name" value="{{inOutItemIndex}}" bindchange="onInOutItemChange">
        <view class="picker-value">{{inOutItemIndex >= 0 ? inOutItems[inOutItemIndex].name : '请选择'}}</view>
      </picker>
      <view class="field-action" bindtap="createInOutItem">新增收支项目</view>
    </view>
    <view class="field">
      <view class="field-label">金额</view>
      <input class="text-input" type="digit" value="{{amount}}" data-field="amount" bindinput="onInput" placeholder="必填" />
    </view>
    <view class="field">
      <view class="field-label">财务员</view>
      <picker mode="selector" range="{{persons}}" range-key="name" value="{{personIndex}}" bindchange="onPersonChange">
        <view class="picker-value">{{personIndex >= 0 ? persons[personIndex].name : '请选择'}}</view>
      </picker>
      <view class="field-action" bindtap="createPerson">新增财务员</view>
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="可不填" />
    </view>
  </view>

  <view class="save-actions">
    <button class="secondary-button save-button" loading="{{saving && !submitAfterSave}}" disabled="{{saving || loading}}" bindtap="saveBill">保存{{type}}单</button>
    <button class="primary-button save-button" data-submit="1" loading="{{saving && submitAfterSave}}" disabled="{{saving || loading}}" bindtap="saveBill">保存并提交</button>
  </view>
</view>
