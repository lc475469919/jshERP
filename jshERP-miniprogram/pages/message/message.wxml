<view class="page">
  <view class="type-tabs">
    <view class="type-tab {{status === '1' ? 'active' : ''}}" data-status="1" bindtap="changeStatus">未读 {{unreadCount}}</view>
    <view class="type-tab {{status === '2' ? 'active' : ''}}" data-status="2" bindtap="changeStatus">已读 {{readCount}}</view>
  </view>
  <button wx:if="{{status === '1' && unreadCount}}" class="secondary-button read-all-button" loading="{{processingAll}}" bindtap="readAll">全部标记已读</button>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!list.length}}" class="state-text">暂无消息</view>

  <view wx:for="{{list}}" wx:key="id" class="message-card">
    <view class="message-main">
      <view class="message-title">{{item.titleText}}</view>
      <view class="message-type">{{item.typeText}}</view>
    </view>
    <view class="message-time" wx:if="{{item.timeText}}">{{item.timeText}}</view>
    <view class="message-content" wx:if="{{item.contentText}}">{{item.contentText}}</view>
    <button wx:if="{{status === '1'}}" class="secondary-button read-button" data-id="{{item.id}}" loading="{{processingId === item.id}}" bindtap="markRead">标记已读</button>
  </view>
</view>
