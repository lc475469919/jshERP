page {
  background: #f4f6f8;
  color: #1f2933;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 8rpx;
}

.title {
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.entry {
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 8rpx;
}
