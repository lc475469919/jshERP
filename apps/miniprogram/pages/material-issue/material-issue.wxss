.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f4f6f8;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: #fff;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 140rpx;
}

.hint {
  padding: 64rpx 0;
  color: #667085;
  text-align: center;
}

.issue-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.issue-head,
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.issue-no {
  color: #101828;
  font-size: 28rpx;
  font-weight: 600;
}

.status {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  color: #1677ff;
  background: #e6f4ff;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.row {
  padding: 8rpx 0;
  color: #667085;
  font-size: 26rpx;
}
